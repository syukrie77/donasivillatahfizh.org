---

<!-- ═══════════ 7. LEGALITAS & TRUST ═══════════ -->
<section class="legalitas py-24 bg-white" id="legalitas">
    <div class="container mx-auto px-6">
        <div class="text-center">
            <span
                class="section-badge reveal inline-flex items-center gap-2 px-4 py-1.5 bg-primary/10 text-primary rounded-full text-sm font-semibold uppercase tracking-wider mb-4"
                >🛡️ Legalitas & Trust</span
            >
            <h2
                class="section-title reveal text-3xl md:text-4xl font-bold font-heading mb-4 text-dark"
            >
                Terpercaya & Terverifikasi
            </h2>
            <p
                class="section-subtitle reveal text-gray-500 max-w-2xl mx-auto leading-relaxed text-lg"
            >
                Donasi Villa Tahfizh berada di bawah naungan yayasan yang legal
                dan terverifikasi
            </p>
        </div>

        <div
            class="legalitas-grid mt-12 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center"
        >
            <div class="legal-cards reveal-left flex flex-col gap-6">
                <div
                    class="legal-card flex items-start gap-4 p-6 bg-gray-50 rounded-2xl border border-gray-100 hover:shadow-md transition-shadow"
                >
                    <div class="legal-icon text-3xl mt-1">📜</div>
                    <div class="legal-info">
                        <h4
                            class="font-bold text-dark font-heading text-lg mb-1"
                        >
                            SK Kemenkumham RI
                        </h4>
                        <p class="text-gray-500 text-sm">
                            AHU-0010190.AH.01.04.Tahun 2018
                        </p>
                    </div>
                </div>
                <div
                    class="legal-card flex items-start gap-4 p-6 bg-gray-50 rounded-2xl border border-gray-100 hover:shadow-md transition-shadow"
                >
                    <div class="legal-icon text-3xl mt-1">🏛️</div>
                    <div class="legal-info">
                        <h4
                            class="font-bold text-dark font-heading text-lg mb-1"
                        >
                            Yayasan Khoiru Ummah Indonesia Madani
                        </h4>
                        <p class="text-gray-500 text-sm">
                            Badan hukum yayasan resmi terdaftar
                        </p>
                    </div>
                </div>
                <div
                    class="legal-card flex items-start gap-4 p-6 bg-gray-50 rounded-2xl border border-gray-100 hover:shadow-md transition-shadow"
                >
                    <div class="legal-icon text-3xl mt-1">📋</div>
                    <div class="legal-info">
                        <h4
                            class="font-bold text-dark font-heading text-lg mb-1"
                        >
                            NPWP Yayasan
                        </h4>
                        <p class="text-gray-500 text-sm">
                            Terdaftar sebagai wajib pajak aktif
                        </p>
                    </div>
                </div>
                <div
                    class="legal-card flex items-start gap-4 p-6 bg-gray-50 rounded-2xl border border-gray-100 hover:shadow-md transition-shadow"
                >
                    <div class="legal-icon text-3xl mt-1">📍</div>
                    <div class="legal-info">
                        <h4
                            class="font-bold text-dark font-heading text-lg mb-1"
                        >
                            Lokasi Terverifikasi
                        </h4>
                        <p class="text-gray-500 text-sm">
                            Komplek Peruri, Jl. Soebagyo Raya Blok Y, Ciledug —
                            Tangerang
                        </p>
                    </div>
                </div>
            </div>

            <div
                class="map-container reveal-right h-[400px] lg:h-[100%] rounded-2xl overflow-hidden shadow-lg border border-gray-100"
            >
                <iframe
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3966.2!2d106.71!3d-6.24!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNsKwMTQnMjQuMCJTIDEwNsKwNDInMzYuMCJF!5e0!3m2!1sid!2sid!4v1700000000000!5m2!1sid!2sid"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                    title="Lokasi Villa Tahfizh"
                    class="w-full h-full border-0 min-h-[400px]"></iframe>
            </div>
        </div>

        <!-- Struktur Pengurus -->
        <div
            class="pengurus-section reveal mt-20 pt-16 border-t border-gray-100"
        >
            <h3
                class="section-title text-center text-2xl font-bold font-heading mb-12 text-dark"
            >
                Struktur Pengurus
            </h3>
            <div class="pengurus-grid grid grid-cols-1 md:grid-cols-3 gap-8">
                <div
                    class="pengurus-card text-center p-8 bg-gray-50 rounded-2xl border border-gray-100 hover:-translate-y-1 transition-transform"
                >
                    <div
                        class="pengurus-avatar w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center text-2xl font-bold font-heading mx-auto mb-4"
                    >
                        K
                    </div>
                    <h4 class="font-bold text-lg text-dark mb-1">
                        Ketua Yayasan
                    </h4>
                    <p class="text-gray-500 text-sm">
                        Pimpinan Yayasan Khoiru Ummah
                    </p>
                </div>
                <div
                    class="pengurus-card text-center p-8 bg-gray-50 rounded-2xl border border-gray-100 hover:-translate-y-1 transition-transform border-b-4 border-b-primary md:border-b-gray-100 md:shadow-[0_10px_30px_rgba(13,124,61,0.1)] md:bg-white md:-translate-y-4 md:hover:-translate-y-5"
                >
                    <div
                        class="pengurus-avatar w-16 h-16 bg-accent text-dark rounded-full flex items-center justify-center text-2xl font-bold font-heading mx-auto mb-4"
                    >
                        S
                    </div>
                    <h4 class="font-bold text-lg text-dark mb-1">Sekretaris</h4>
                    <p class="text-gray-500 text-sm">
                        Administrasi & Dokumentasi
                    </p>
                </div>
                <div
                    class="pengurus-card text-center p-8 bg-gray-50 rounded-2xl border border-gray-100 hover:-translate-y-1 transition-transform"
                >
                    <div
                        class="pengurus-avatar w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center text-2xl font-bold font-heading mx-auto mb-4"
                    >
                        B
                    </div>
                    <h4 class="font-bold text-lg text-dark mb-1">Bendahara</h4>
                    <p class="text-gray-500 text-sm">Pengelolaan Keuangan</p>
                </div>
            </div>
        </div>
    </div>
</section>
