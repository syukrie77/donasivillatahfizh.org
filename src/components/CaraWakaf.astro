---

<!-- ═══════════ 6. CARA BERWAKAF ═══════════ -->
<section class="cara-wakaf py-24 bg-gray-50" id="wakaf">
    <div class="container mx-auto px-6">
        <div class="text-center">
            <span
                class="section-badge reveal inline-flex items-center gap-2 px-4 py-1.5 bg-primary/10 text-primary rounded-full text-sm font-semibold uppercase tracking-wider mb-4"
                >💳 Cara Berwakaf</span
            >
            <h2
                class="section-title reveal text-3xl md:text-4xl font-bold font-heading mb-4 text-dark"
            >
                Mudah & Cepat untuk Berwakaf
            </h2>
            <p
                class="section-subtitle reveal text-gray-500 max-w-2xl mx-auto leading-relaxed text-lg"
            >
                Pilih metode pembayaran yang paling nyaman untuk Anda
            </p>
        </div>

        <div
            class="cara-wakaf-grid mt-12 grid grid-cols-1 lg:grid-cols-3 gap-8"
        >
            <!-- QRIS -->
            <div
                class="cara-wakaf-card reveal p-8 bg-white border border-gray-100 rounded-3xl shadow-lg relative overflow-hidden group hover:-translate-y-1 transition-transform"
            >
                <div
                    class="card-step absolute -top-4 -right-4 w-16 h-16 bg-primary/10 text-primary font-heading font-black text-3xl rounded-full flex items-center justify-center"
                >
                    1
                </div>
                <div class="card-icon text-4xl mb-6">📱</div>
                <h3 class="text-xl font-bold text-dark font-heading mb-3">
                    Scan QRIS
                </h3>
                <p class="text-gray-500 mb-6 text-sm leading-relaxed">
                    Scan kode QRIS di bawah ini menggunakan aplikasi mobile
                    banking atau e-wallet Anda
                </p>
                <div
                    class="bg-gray-50 p-4 rounded-xl border border-gray-100 flex justify-center"
                >
                    <img
                        src="/brosur_donasi.jpeg"
                        alt="QRIS Code"
                        class="qris-image w-full max-w-[200px] h-auto rounded-lg shadow-sm"
                        loading="lazy"
                        style="object-fit: cover; object-position: center; max-height: 200px;"
                    />
                </div>
            </div>

            <!-- Bank Transfer -->
            <div
                class="cara-wakaf-card reveal p-8 bg-white border border-gray-100 rounded-3xl shadow-lg relative overflow-hidden group hover:-translate-y-1 transition-transform"
                style="transition-delay: 100ms;"
            >
                <div
                    class="card-step absolute -top-4 -right-4 w-16 h-16 bg-primary/10 text-primary font-heading font-black text-3xl rounded-full flex items-center justify-center"
                >
                    2
                </div>
                <div class="card-icon text-4xl mb-6">🏦</div>
                <h3 class="text-xl font-bold text-dark font-heading mb-3">
                    Transfer Bank BSI
                </h3>
                <p class="text-gray-500 mb-6 text-sm leading-relaxed">
                    Transfer ke rekening Bank Syariah Indonesia (BSI) berikut:
                </p>

                <div class="bank-details space-y-4">
                    <div
                        class="detail-row flex justify-between items-center pb-3 border-b border-gray-100"
                    >
                        <span class="label text-gray-400 text-sm">Bank</span>
                        <span class="value font-semibold text-dark text-right"
                            >BSI (Bank Syariah Indonesia)</span
                        >
                    </div>
                    <div
                        class="detail-row flex justify-between items-center pb-3 border-b border-gray-100"
                    >
                        <span class="label text-gray-400 text-sm"
                            >No. Rekening</span
                        >
                        <span
                            class="value font-heading font-bold text-lg text-primary text-right"
                            >5001116004</span
                        >
                    </div>
                    <div class="detail-row flex justify-between items-center">
                        <span class="label text-gray-400 text-sm"
                            >Atas Nama</span
                        >
                        <span class="value font-semibold text-dark text-right"
                            >Donasi Villa Tahfidz</span
                        >
                    </div>
                </div>
            </div>

            <!-- WhatsApp -->
            <div
                class="cara-wakaf-card reveal p-8 bg-white border border-gray-100 rounded-3xl shadow-lg relative overflow-hidden group hover:-translate-y-1 transition-transform"
                style="transition-delay: 200ms;"
            >
                <div
                    class="card-step absolute -top-4 -right-4 w-16 h-16 bg-primary/10 text-primary font-heading font-black text-3xl rounded-full flex items-center justify-center"
                >
                    3
                </div>
                <div class="card-icon text-4xl mb-6">💬</div>
                <h3 class="text-xl font-bold text-dark font-heading mb-3">
                    Konfirmasi via WhatsApp
                </h3>
                <p class="text-gray-500 mb-8 text-sm leading-relaxed">
                    Setelah transfer, konfirmasi donasi Anda melalui WhatsApp
                    untuk mendapatkan bukti penerimaan
                </p>

                <a
                    href="https://wa.me/6287847972272?text=Assalamualaikum,%20saya%20ingin%20konfirmasi%20wakaf%20untuk%20Villa%20Tahfizh"
                    target="_blank"
                    class="btn btn-primary w-full py-4 bg-gradient-to-br from-[#25D366] to-[#128C7E] text-white rounded-xl shadow-[0_4px_14px_rgba(37,211,102,0.3)] hover:-translate-y-0.5 transition-transform flex justify-center items-center gap-2 font-semibold font-heading"
                >
                    💬 Konfirmasi WhatsApp
                </a>
            </div>
        </div>
    </div>
</section>
